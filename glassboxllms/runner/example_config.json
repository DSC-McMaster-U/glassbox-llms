{
  "model": {
    "name": "llama-3.3-8b",
    "checkpoint": "meta-llama/Meta-Llama-3.3-8B",
    "device": "cuda",
    "dtype": "float16",
    "wrapper_type": "transformers"
  },
  "dataset": {
    "path": "your/path/to/the/dataset",
    "name": "name/of/configuration",
    "data_dir": "load/all/files/in/this/subdir",
    "data_files": "specific/file/to/load",
    "split": "train",
    "preprocess": {
      "max_length": {
        "text_column": "text",
        "max_len": 512
      }
    }
  },
  "experiment": {
    "type": "dummy",
    "parameters": {
      "lr": 2e-5,
      "bsz": 8,
      "time": 3
    },
    "seed": 0
  },
  "tracking": {
    "enabled": true,
    "type": "wandb",
    "project": "example-project",
    "entity": "awesome-team",
    "tags": ["llama", "baseline"],
    "config": {
      "optimizer": "adamw-8bit"
    }
  },
  "output": {
    "base_dir": "runs/",
    "name": "run-001"
  }
}
